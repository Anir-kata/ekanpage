PORT=3000
# Single origin example:
# CORS_ORIGIN=https://anirportfolio.vercel.app
# Multiple origins example (comma-separated):
# CORS_ORIGIN=https://anirportfolio.vercel.app,https://ekanpagecontrol.vercel.app
CORS_ORIGIN=https://anirportfolio.vercel.app

# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me-local-db-password
DB_NAME=postgres
DB_SYNC=false

AUTH_USER=USERNAME
AUTH_PASSWORD=PASSWORD
JWT_SECRET=JWT_SECRET_KEY
JWT_EXPIRES_IN=1d
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=60000
