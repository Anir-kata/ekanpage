PORT=3000
CORS_ORIGIN=https://ekanpagecontrol.vercel.app

# Preferred for cloud Postgres (Neon):
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me-local-db-password
DB_NAME=postgres
DB_SYNC=false

AUTH_USER=change-me-admin
AUTH_PASSWORD=change-me-admin-password
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRES_IN=1d
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=60000
